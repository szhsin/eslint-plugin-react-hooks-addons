{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "oxc", "typescript", "import", "jsdoc"],
  "ignorePatterns": [
    "**/coverage/",
    "**/dist/",
    "**/types/",
    "**/build/",
    "**/static/",
    "**/*.d.ts"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "rules": {
    "no-console": ["error", { "allow": ["warn", "error"] }],
    "typescript/no-unsafe-type-assertion": "off",
    "typescript/require-await": "error"
  }
}
